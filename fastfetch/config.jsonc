{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    //"type": "small",
    //"padding": {
    //  "top": 2
    //},
    //"source": "~/.config/fastfetch/arch_btw.jpg",
    "source": "~/.config/fastfetch/34.gif",
    "width": 20,
    "height": 10
  },
  "modules": [
    "title",
    //"separator",
    {
        "type": "custom",
	"format": "\u001b[90mв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ"
    },
    {
        "type": "os",
        "key": " os",
        "keyColor": "yellow"
    },
    {
